# 复制为 .env 并填写真实值（此文件可提交到 GitHub，.env 不可提交）

# ===== 后端配置（在 backend/.env 中配置）=====

# LLM API Key（必填）
LLM_API_KEY=your_api_key_here

# LLM 服务地址（DeepSeek 默认）
LLM_BASE_URL=https://api.deepseek.com
# SiliconFlow 示例：LLM_BASE_URL=https://api.siliconflow.cn/v1

# 使用的模型
LLM_MODEL=deepseek-chat
# SiliconFlow 示例：LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# CORS 允许来源（生产环境改为 Vercel 域名）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 生产：CORS_ORIGINS=https://your-app.vercel.app

# ===== 前端配置（在 frontend/.env 中配置）=====
# 后端 API 地址（本地留空走 Vite proxy，生产填写 Railway/Render 地址）
# VITE_API_BASE_URL=https://your-backend.railway.app
