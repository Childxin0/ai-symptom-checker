# 复制为 .env 并填写真实值（此文件可提交到 GitHub，.env 不可提交）
# Copy to .env and fill in real values (this file can be committed, .env cannot)

# ===== 后端配置（在 backend/.env 中配置）=====
# Anthropic API Key（必填）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic 模型（可选，默认 claude-sonnet-4-20250514）
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# CORS 允许的前端域名（逗号分隔，部署后改为 Vercel 域名）
# 本地开发：
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 生产环境示例（填写你的 Vercel 域名）：
# CORS_ORIGINS=https://your-app.vercel.app

# ===== 前端配置（在 frontend/.env 中配置）=====
# 后端 API 地址（本地开发留空，生产环境填写 Railway/Render 后端地址）
# VITE_API_BASE_URL=https://your-backend.railway.app
